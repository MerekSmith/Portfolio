 /* Updates the background position if using IE/Edge. Navbar becomes fixed so this makes the background go back up to the actual top of page. */
 .ie-parallax { 
  background-position-y: 0px !important;
}

 /* responsive css, fixes parallax issues on phone.*/
 @media only screen and (max-width: 800px) {
	.parallax { 
		background-position-y: 0px;
	}

	.about-me {
		padding: 30px 30px !important;
	}

	.personal { 
		padding: 30px 40px !important;
	}

}