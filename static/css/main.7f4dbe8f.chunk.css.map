.sticky-nav {
  /* position: sticky;
  top: 0; */
  z-index: 999; /*This makes the navbar always be in front (everything goes under it as you scroll up) */
  /* opacity: .8; */
}

.nav-btn {
  width: 140px !important;
  color: #fff !important;
  font-size: 16px;
  padding: 4px !important;
  margin-right: 10px;
  margin-top: 2.5px;
  margin-bottom: 2.5px;
  opacity: 1;
  border: 1px solid;
}

.nav-resume-btn {
  width: 140px !important;
  font-size: 16px;
  padding: 4px !important;
  margin-right: 10px;
  margin-top: 2.5px;
  margin-bottom: 2.5px;
  opacity: 1;
  border: 1px solid;
}

.btn-danger {
  background-color: red;
}

.nav-icon {
  width: 24px;
  height: 24px;
  font-size: 24px;
  /* margin-right: 10px; */
  float: left;
  color: dodgerblue;
}

.favicon {
  animation: favicon-spin infinite 20s linear;
  /* height: 40vmin; */
}

@keyframes favicon-spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}
