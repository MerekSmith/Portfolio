
.hero-home-container {
  
  background: url("../assets/images/parallax_spiderverse.jpg") no-repeat center;
  background-size: cover;
  background-attachment: fixed;
	height: 100vh;
	opacity: .8;
  overflow: hidden;
  position: relative;
  /* Useful for any “absolute” positioned elements inside */
}

.home {
  padding-top: 15px;
  position: absolute;
  bottom: 10%;
  width: 100%;
  text-align: center;
}

.homeContents {
  margin: auto;
  width: 80%;
  text-align: center;
  color: white;
}

.home-heading {
  max-width: 750px;
  margin: 0 auto;
  background-color: #111;
  color: #fff;
  border: 1px solid #dee2e6!important;
  padding: 10px;
  font-size: 25px;
  letter-spacing: 5px;
  opacity: .85;
}

.icon-group {
  margin-top: 5px;
}

.icons {
  width: 50px;
  height: 50px;
  margin: 10px;
}

.icons:hover {
  -ms-transform: rotate(-10deg);
  -webkit-transform: rotate(-10deg);
  -moz-transform: rotate(-10deg);
  -o-transform: rotate(-10deg);
  transform: rotate(-10deg);
}

/* .iconGroup {
  margin-top: 80px;
} */

.icon {
  display: inline-block;
}
